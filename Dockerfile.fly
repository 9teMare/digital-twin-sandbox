# syntax=docker/dockerfile:1
#
# Production image for Fly.io — single container that serves BOTH the built
# Vue SPA and the Flask API on the same origin (port 8080).
#
#   Stage 1: build the frontend with Vite (relative API base → same origin)
#   Stage 2: install backend deps with uv and run Flask, which also serves dist/

############################
# Stage 1 — build frontend #
############################
FROM node:20-slim AS frontend-build

WORKDIR /app/frontend

# Install deps first (better layer caching)
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

# App source + shared locales (vite alias '@locales' resolves to ../locales)
COPY frontend/ ./
COPY locales/ /app/locales/

# Empty base URL → axios uses relative '/api/...', hitting the same origin
ENV VITE_API_BASE_URL=""
RUN npm run build


#############################
# Stage 2 — backend runtime #
#############################
FROM python:3.11 AS runtime

# Fast, reproducible Python installs
COPY --from=ghcr.io/astral-sh/uv:0.9.26 /uv /uvx /bin/

ENV PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    UV_PROJECT_ENVIRONMENT=/app/backend/.venv \
    FRONTEND_DIST=/app/frontend/dist \
    FLASK_HOST=0.0.0.0 \
    FLASK_PORT=8080 \
    FLASK_DEBUG=false

WORKDIR /app/backend

# Install Python deps. NOTE: the install and the slim-down MUST happen in the
# same RUN layer — Docker layers are additive, so deleting files in a later
# layer would not shrink the image.
#
# The default PyPI `torch` (pinned in uv.lock) bundles multi-GB NVIDIA CUDA
# libraries that this app never uses (all model inference happens via remote
# LLM/Zep APIs). After syncing, we swap torch for the CPU-only build and purge
# the now-orphaned NVIDIA/Triton packages, keeping the image under Fly's 8GB.
COPY backend/pyproject.toml backend/uv.lock ./
RUN set -eux; \
    uv sync --frozen --no-dev --no-cache; \
    VENV=/app/backend/.venv; \
    PY="$VENV/bin/python"; \
    TORCH_VER="$($PY -c 'import torch; print(torch.__version__.split("+")[0])' 2>/dev/null || true)"; \
    ORPHANS="$(uv pip freeze --python "$PY" | grep -iE '^(nvidia-|triton)' | cut -d'=' -f1 || true)"; \
    if [ -n "$TORCH_VER" ]; then uv pip uninstall --python "$PY" torch; fi; \
    if [ -n "$ORPHANS" ]; then uv pip uninstall --python "$PY" $ORPHANS; fi; \
    if [ -n "$TORCH_VER" ]; then \
      uv pip install --python "$PY" --no-cache "torch==$TORCH_VER" --index-url https://download.pytorch.org/whl/cpu \
      || uv pip install --python "$PY" --no-cache torch --index-url https://download.pytorch.org/whl/cpu; \
      "$PY" -c "import torch; print('torch', torch.__version__)"; \
    fi; \
    rm -rf /root/.cache

# Backend source + shared locales
COPY backend/ ./
COPY locales/ /app/locales/

# Built SPA from stage 1
COPY --from=frontend-build /app/frontend/dist /app/frontend/dist

# Put the venv first on PATH so `python` (and sys.executable used to spawn
# simulation subprocesses) resolves to the project environment.
ENV PATH="/app/backend/.venv/bin:$PATH"

WORKDIR /app
EXPOSE 8080

# Flask serves the API and the built SPA. run.py reads FLASK_HOST/PORT/DEBUG.
CMD ["python", "backend/run.py"]
